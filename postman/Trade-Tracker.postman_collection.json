{
  "info": {
    "name": "Trade Tracker API",
    "description": "Phase 1 (Customers) + Phase 2 (Trades) + Phase 3 (Reports). Set baseUrl to your server (e.g. http://localhost:3000).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "customerId", "value": "" }
  ],
  "item": [
    {
      "name": "Customers",
      "item": [
        {
          "name": "Create customer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane@example.com\",\n  \"phone\": \"+1234567890\"\n}"
            },
            "url": "{{baseUrl}}/customers",
            "description": "Create a new customer (Phase 1)."
          }
        },
        {
          "name": "List all customers",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/customers",
            "description": "Get all customers. Response includes totalPaid, timesVisited, firstSaleDate after trades."
          }
        },
        {
          "name": "Get customer by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/customers/{{customerId}}",
            "description": "Get one customer. Set customerId in collection/request (e.g. from create or list response)."
          }
        },
        {
          "name": "Update customer",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Smith\",\n  \"phone\": \"+0987654321\"\n}"
            },
            "url": "{{baseUrl}}/customers/{{customerId}}",
            "description": "Partial update. Only send fields to change."
          }
        },
        {
          "name": "Delete customer",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/customers/{{customerId}}",
            "description": "Delete customer by ID."
          }
        }
      ]
    },
    {
      "name": "Trades",
      "item": [
        {
          "name": "Process trade (existing customer by email)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane@example.com\",\n  \"deviceName\": \"iPhone 12\",\n  \"amountPaid\": 250\n}"
            },
            "url": "{{baseUrl}}/trades",
            "description": "Finds customer by email, creates trade, updates customer totalPaid/timesVisited/firstSaleDate."
          }
        },
        {
          "name": "Process trade (existing customer by phone)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+1234567890\",\n  \"deviceName\": \"MacBook Air\",\n  \"amountPaid\": 600\n}"
            },
            "url": "{{baseUrl}}/trades",
            "description": "Finds customer by phone, creates trade, updates stats."
          }
        },
        {
          "name": "Process trade (new customer)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"new@example.com\",\n  \"name\": \"New Customer\",\n  \"phone\": \"+1111111111\",\n  \"deviceName\": \"iPad\",\n  \"amountPaid\": 400\n}"
            },
            "url": "{{baseUrl}}/trades",
            "description": "No customer with this email/phone → creates customer then creates trade. Name and email required for new customer."
          }
        },
        {
          "name": "List all trades",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/trades",
            "description": "All trades, newest first."
          }
        },
        {
          "name": "List trades by customer",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/trades?customerId={{customerId}}",
            "description": "Trades for one customer. Set customerId variable (MongoDB ObjectId)."
          }
        }
      ]
    },
    {
      "name": "Reports",
      "item": [
        {
          "name": "Top customers",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/reports/top-customers?limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["reports", "top-customers"],
              "query": [
                { "key": "limit", "value": "10", "description": "Optional, default 10, max 100" }
              ]
            },
            "description": "Returns name, totalPaid, devicesSold, firstSaleDate. Sorted by totalPaid descending."
          }
        },
        {
          "name": "Customers by date range",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/reports?startDate=2025-01-01&endDate=2025-12-31&limit=100",
              "host": ["{{baseUrl}}"],
              "path": ["reports"],
              "query": [
                { "key": "startDate", "value": "2025-01-01", "description": "Required, ISO 8601" },
                { "key": "endDate", "value": "2025-12-31", "description": "Required, ISO 8601" },
                { "key": "limit", "value": "100", "description": "Optional, max 500" }
              ]
            },
            "description": "Customers who had at least one trade in [startDate, endDate] with in-range totalPaid and devicesSold."
          }
        },
        {
          "name": "Dashboard summary",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/reports/summary?days=30",
              "host": ["{{baseUrl}}"],
              "path": ["reports", "summary"],
              "query": [
                { "key": "days", "value": "30", "description": "Optional; limit stats to last N days (1-365)" }
              ]
            },
            "description": "Total customers, total revenue, total trades. Omit days for all-time stats."
          }
        },
        {
          "name": "Sales by period",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/reports/sales-by-period?groupBy=day",
              "host": ["{{baseUrl}}"],
              "path": ["reports", "sales-by-period"],
              "query": [
                { "key": "startDate", "value": "2025-01-01", "description": "Optional" },
                { "key": "endDate", "value": "2025-12-31", "description": "Optional" },
                { "key": "groupBy", "value": "day", "description": "day or month" }
              ]
            },
            "description": "Revenue and count by day or month. Good for charts."
          }
        },
        {
          "name": "Top devices",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/reports/top-devices?limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["reports", "top-devices"],
              "query": [
                { "key": "limit", "value": "10", "description": "Optional, default 10, max 100" }
              ]
            },
            "description": "Most sold device names with count."
          }
        }
      ]
    }
  ]
}
